{
  "name": "set_home_temperature_override",
  "description": "Set temporary temperature overrides for multiple zones/rooms in a home simultaneously. Allows setting custom heating/cooling power and target temperature for specific rooms, bypassing their schedules. Each override can be configured with its own termination conditions (e.g., manual clear or timed duration).",
  "parameters": {
    "properties": {
      "home_id": {
        "description": "The ID of the home where zones will be overridden",
        "type": "integer"
      },
      "overlays": {
        "description": "List of temperature overrides to apply to different rooms",
        "items": {
          "properties": {
            "overlay": {
              "description": "The override configuration for this room",
              "properties": {
                "setting": {
                  "description": "The heating/cooling settings for the override",
                  "properties": {
                    "isBoost": {
                      "description": "Whether boost mode is enabled for this override",
                      "type": "boolean"
                    },
                    "power": {
                      "description": "Whether to turn the heating/cooling on or off",
                      "enum": [
                        "ON",
                        "OFF"
                      ],
                      "type": "string"
                    },
                    "temperature": {
                      "description": "The target temperature setting",
                      "properties": {
                        "celsius": {
                          "description": "Target temperature in Celsius",
                          "type": "number"
                        }
                      },
                      "type": "object"
                    },
                    "type": {
                      "description": "The type of control (e.g., HEATING, COOLING)",
                      "type": "string"
                    }
                  },
                  "required": [
                    "power"
                  ],
                  "type": "object"
                },
                "termination": {
                  "description": "How and when the override should terminate",
                  "properties": {
                    "durationInSeconds": {
                      "description": "Duration in seconds if using TIMER termination type",
                      "type": "integer"
                    },
                    "typeSkillBasedApp": {
                      "description": "Type of termination: MANUAL (until cleared manually) or TIMER (automatic after duration)",
                      "enum": [
                        "MANUAL",
                        "TIMER"
                      ],
                      "type": "string"
                    }
                  },
                  "required": [
                    "typeSkillBasedApp"
                  ],
                  "type": "object"
                }
              },
              "required": [
                "setting",
                "termination"
              ],
              "type": "object"
            },
            "room": {
              "description": "The zone/room ID to apply the override to",
              "type": "integer"
            }
          },
          "required": [
            "room",
            "overlay"
          ],
          "type": "object"
        },
        "type": "array"
      }
    },
    "required": [
      "home_id",
      "overlays"
    ],
    "type": "object"
  },
  "request": {
    "method": "POST",
    "url": "https://my.tado.com/api/v2/homes/{home_id}/overlay",
    "headers": {
      "content-type": "application/json"
    },
    "query": {},
    "body": {
      "overlays": {
        "$param": "overlays"
      }
    },
    "content_type": "application/json"
  },
  "requires_auth": true
}